{
	"schemaVersion": 1,
	"id": "pingtabmod",
	"version": "${version}",
	"name": "PingTabMod",
	"description": "A mod that shows player ping as numbers in the tab list",
	"authors": [
		"Natxo"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/tab-ping",
		"sources": "https://github.com/Natxo09/tab-ping",
		"issues": "https://github.com/Natxo09/tab-ping/issues"
	},
	"license": "MIT",
	"icon": "assets/pingtabmod/icon.png",
	"environment": "client",
	"entrypoints": {
		"main": [
			"net.natxo.pingtabmod.PingTabMod"
		],
		"client": [
			"net.natxo.pingtabmod.PingTabModClient"
		]
	},
	"mixins": [
		{
			"config": "pingtabmod.client.mixins.json",
			"environment": "client"
		}
	],
	"accessWidener": "pingtabmod.accesswidener",
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}
